# =============================================================================
# Environment Configuration — Edit these values for your environment
# =============================================================================
# Usage: source config.env

export REGION="us-east-1"
export ACCOUNT_ID="123456789012"           # Your AWS account ID

# Aurora Cluster
export CLUSTER_ID="e2e-iam-test"
export INSTANCE_ID="e2e-iam-test-writer"
export INSTANCE_CLASS="db.t3.medium"
export ENGINE_VERSION="8.0.mysql_aurora.3.08.0"
export DB_MASTER_USER="admin"
export DB_MASTER_PASS="CHANGE_ME"          # Set a secure password
export DB_IAM_USER="iam_user"

# Networking — replace with your VPC resources
export DB_SUBNET_GROUP="your-db-subnet-group"
export VPC_SECURITY_GROUP="sg-xxxxxxxxx"
export VPC_SUBNETS="subnet-aaaa subnet-bbbb subnet-cccc"

# RDS Proxy
export PROXY_NAME="e2e-iam-proxy"
export PROXY_ROLE_NAME="e2e-iam-proxy-role"

# Client IAM role (EC2 instance role, Lambda role, etc.)
export CLIENT_ROLE_NAME="your-client-role"

echo "Config loaded: cluster=$CLUSTER_ID proxy=$PROXY_NAME region=$REGION"
